{
  "expo": {
    "name": "Cheers",
    "slug": "cheers-mobile",
    "scheme": "cheers",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cheers.mobile"
    },
    "android": {
      "package": "com.cheers.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#050816"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
